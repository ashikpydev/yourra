# ============================================================
# LOCAL MODE
# true  = run fully on your computer (SQLite + local disk + mock transcription),
#         no Supabase/R2/Gemini accounts required. Great for testing.
# false = production: uses the real Supabase + Cloudflare R2 values below.
# ============================================================
LOCAL_MODE=true
LOCAL_DB_PATH=./yourra_local.db
LOCAL_STORAGE_DIR=./local_storage

# Public URL (used in emails). Set to your domain in production.
APP_BASE_URL=http://127.0.0.1:8000

# Redis job queue (optional). Set in production to run transcription on a
# separate worker (scales + survives deploys). Blank = run jobs in-process.
REDIS_URL=

# Email (SMTP) for notifying users when an admin creates their account.
# Leave SMTP_HOST blank to disable sending (admin page will show the password instead).
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASS=an app password, SMTP_FROM=you@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Supabase (only used when LOCAL_MODE=false)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Admin panel (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# App
APP_SECRET_KEY=change-me
MAX_UPLOAD_MB=500
BKASH_NUMBER=01XXXXXXXXX
WHATSAPP_NUMBER=+8801XXXXXXXXX

# Session cookie security.
# Keep "false" for local http://localhost testing (browsers reject Secure
# cookies over plain HTTP, which would break login locally).
# Set to "true" in production once you serve the site over HTTPS.
COOKIE_SECURE=false

# Trial / chunking
TRIAL_MINUTES=5
CHUNK_TARGET_SECONDS=600
CHUNK_HARD_MAX_SECONDS=660
SILENCE_THRESH_DBFS=-40
MIN_SILENCE_LEN_MS=500

TMP_DIR=/tmp/yourra
R2_RETENTION_DAYS=7
